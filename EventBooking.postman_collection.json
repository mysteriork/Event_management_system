{
  "info": {
    "name": "Event Booking System",
    "_postman_id": "event-booking-collection-v1",
    "description": "Mini Event Management System — API Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Events",
      "item": [
        {
          "name": "GET All Upcoming Events",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["events"]
            }
          }
        },
        {
          "name": "POST Create Event",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Node.js Workshop\",\n  \"description\": \"Beginner-friendly Node.js hands-on workshop.\",\n  \"date\": \"2025-12-01T10:00:00\",\n  \"total_capacity\": 50\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["events"]
            }
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "POST Book Ticket",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": 1,\n  \"event_id\": 1,\n  \"tickets_booked\": 2\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/bookings",
              "host": ["{{baseUrl}}"],
              "path": ["bookings"]
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "GET User Bookings",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/1/bookings",
              "host": ["{{baseUrl}}"],
              "path": ["users", "1", "bookings"]
            }
          }
        }
      ]
    },
    {
      "name": "Attendance",
      "item": [
        {
          "name": "POST Check In with Code",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"EVT-A3F9K2\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/events/1/attendance",
              "host": ["{{baseUrl}}"],
              "path": ["events", "1", "attendance"]
            }
          }
        }
      ]
    }
  ]
}
